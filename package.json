{
  "name": "react-init",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:emu": "firebase emulators:start --project demo-lams-v0",
    "test": "vitest run test --exclude test/rules.spec.js && firebase emulators:exec --project demo-lams-v0 \"vitest run test/rules.spec.js && playwright test\"",
    "test:rules": "vitest run test/rules.spec.js",
    "test:unit": "vitest run test --exclude test/rules.spec.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
